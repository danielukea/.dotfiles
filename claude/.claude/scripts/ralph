#!/usr/bin/env bash
set -euo pipefail

# ralph — Headless Claude loop that implements a plan file step by step.
#
# Each iteration spawns a fresh `claude -p` process that:
#   1. Reads the plan file to find the next incomplete step
#   2. Understands the desired outcome
#   3. Implements it
#   4. Verifies (per the injected prompt, or using judgment)
#   5. Marks the step done in the plan file
#
# Progress is checkpointed via git commits on a ralph/<plan-name> branch.

# ── Defaults ──────────────────────────────────────────────────────────────────
MAX_ITERATIONS=20
MODEL="opus"
DRY_RUN=false
PROMPT_FILE=""
PROMPT_ONLY=false

# ── Usage ─────────────────────────────────────────────────────────────────────
usage() {
  cat <<EOF
Usage: ralph <plan-file> [OPTIONS]

Headless Claude loop — implements a plan file one step at a time.

Each iteration spawns a fresh claude -p with a clean context window. It reads
the plan, finds the next unchecked step, implements it, verifies, and marks it
done. Ralph commits after each iteration on a ralph/<plan-name> branch.

Options:
  --max-iterations <N>   Stop after N iterations (default: $MAX_ITERATIONS)
  --model <model>        Claude model to use (default: $MODEL)
  --prompt <file>        Project prompt to append after base prompt
  --prompt-only          Use --prompt file as the ENTIRE prompt (skip base)
  --dry-run              Show the prompt without executing
  -h, --help             Show this help message

Writing Plans:
  Steps are OUTCOMES — what should be true when done — not implementation
  instructions. Claude decides how to implement. The plan provides context.

  Good steps:
    - [ ] Users can be looked up by email address.
    - [ ] The API returns paginated results for /api/contacts.
    - [ ] The CLI accepts a --verbose flag that enables debug logging.

  Bad steps (too prescriptive):
    - [ ] Create app/services/user_lookup.rb with a find_by_email method.
    - [ ] Add pagination to ContactsController#index using kaminari.

  Plan structure:

    # Feature Name
    Brief context about what we're building and why.

    ## Context
    - **Tests**: bin/rspec spec/
    - **Lint**: rubocop -a
    - **Reference files**: path/to/similar/pattern.rb

    ## Architecture (optional, for bigger features)
    - Constraints and patterns that every iteration should follow
    - Where things live, naming conventions, error handling approach

    ## Steps
    - [ ] First outcome.
    - [ ] Second outcome.

  The Context section tells Claude what commands to run. The Architecture
  section keeps independent iterations aligned on bigger features. Steps
  are pure outcomes — verification comes from the --prompt file.

Project Prompts (--prompt):
  Inject project-specific workflow after the base prompt. The base prompt
  is generic (understand → implement → verify). The prompt file adds
  project-specific verification: TDD protocol, lint commands, visual QA.

  Available prompts in ~/.claude/prompts/:
    wealthbox-tdd.md       TDD red-green-refactor + rubocop
    prototype-visual.md    TDD + browser screenshots + DX review

  Use --prompt-only to replace the base prompt entirely with your own.

Examples:
  ralph plan.md                                            # Generic, uses plan's Context for verification
  ralph plan.md --prompt ~/.claude/prompts/wealthbox-tdd.md  # Wealthbox TDD workflow
  ralph plan.md --max-iterations 3 --dry-run               # Preview with 3-iteration cap
  ralph plan.md --prompt-only --prompt custom.md           # Fully custom prompt

Tips:
  - Always --dry-run first to verify the prompt looks right
  - Use --max-iterations 3 when testing a new plan
  - Use /ralph-plan to convert a design doc into an outcome-driven plan
  - Ctrl-C cleanly exits with a summary
  - Review the branch before merging: git log --oneline main..ralph/<name>
EOF
  exit 0
}

# ── Parse args ────────────────────────────────────────────────────────────────
PLAN_FILE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --max-iterations)
      MAX_ITERATIONS="$2"
      shift 2
      ;;
    --model)
      MODEL="$2"
      shift 2
      ;;
    --prompt)
      PROMPT_FILE="$2"
      shift 2
      ;;
    --prompt-only)
      PROMPT_ONLY=true
      shift
      ;;
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    -h|--help)
      usage
      ;;
    -*)
      echo "Error: Unknown option $1" >&2
      usage
      ;;
    *)
      if [[ -z "$PLAN_FILE" ]]; then
        PLAN_FILE="$1"
      else
        echo "Error: Unexpected argument $1" >&2
        usage
      fi
      shift
      ;;
  esac
done

if [[ -z "$PLAN_FILE" ]]; then
  echo "Error: Plan file is required" >&2
  usage
fi

# Validate --prompt-only requires --prompt
if [[ "$PROMPT_ONLY" = true && -z "$PROMPT_FILE" ]]; then
  echo "Error: --prompt-only requires --prompt <file>" >&2
  exit 1
fi

# ── Resolve plan file to absolute path ────────────────────────────────────────
if [[ ! "$PLAN_FILE" = /* ]]; then
  PLAN_FILE="$(cd "$(dirname "$PLAN_FILE")" && pwd)/$(basename "$PLAN_FILE")"
fi

if [[ ! -f "$PLAN_FILE" ]]; then
  echo "Error: Plan file not found: $PLAN_FILE" >&2
  exit 1
fi

# ── Resolve prompt file to absolute path ─────────────────────────────────────
if [[ -n "$PROMPT_FILE" ]]; then
  if [[ ! "$PROMPT_FILE" = /* ]]; then
    PROMPT_FILE="$(cd "$(dirname "$PROMPT_FILE")" && pwd)/$(basename "$PROMPT_FILE")"
  fi
  if [[ ! -f "$PROMPT_FILE" ]]; then
    echo "Error: Prompt file not found: $PROMPT_FILE" >&2
    exit 1
  fi
fi

# ── Derive branch name ───────────────────────────────────────────────────────
plan_basename="$(basename "$PLAN_FILE" .md)"
BRANCH_NAME="ralph/${plan_basename}"

# ── Count remaining steps ─────────────────────────────────────────────────────
count_remaining() {
  local count
  count=$(grep -cE '^\s*- \[ \]' "$PLAN_FILE" 2>/dev/null) || true
  echo "${count:-0}"
}

remaining=$(count_remaining)
if [[ "$remaining" -eq 0 ]]; then
  echo "No incomplete steps found in $PLAN_FILE — nothing to do."
  exit 0
fi

echo "ralph: Found $remaining incomplete step(s) in $(basename "$PLAN_FILE")"

# ── Build allowed tools ───────────────────────────────────────────────────────
# Always include Figma tools — the agent will only use them when relevant
ALLOWED_TOOLS="Bash Read Edit Write Grep Glob Task WebFetch mcp__figma__get_screenshot mcp__figma__get_design_context mcp__figma__get_metadata mcp__figma__get_variable_defs"

# ── Build prompt ──────────────────────────────────────────────────────────────
build_prompt() {
  if [[ "$PROMPT_ONLY" = true ]]; then
    # --prompt-only: use the prompt file as the entire prompt, just prepend plan file ref
    echo "Plan file: $PLAN_FILE"
    echo ""
    cat "$PROMPT_FILE"
  else
    # Base prompt — generic and outcome-driven
    cat <<PROMPT
You are implementing a plan step by step. Each step describes an OUTCOME —
what should be true when you're done — not exact implementation instructions.

Plan file: $PLAN_FILE

For the next incomplete step (marked \`- [ ]\`):

PHASE 1 — UNDERSTAND (before writing any code):
1. Read the step carefully. Understand the desired outcome.
2. Read the plan's Context section for test/lint commands and project info.
3. If the plan has an Architecture section, read it. Follow its constraints
   and patterns — they ensure consistency across iterations.
4. Explore the codebase — find relevant files, existing patterns, and
   conventions. Understand what already exists before deciding what to build.
5. Think through your approach. Consider alternatives. Pick the simplest
   path that achieves the outcome.

PHASE 2 — IMPLEMENT:
6. Write the code to achieve the outcome.
7. If the injected prompt below defines a verification protocol, follow it.
   If not, use your judgment based on the plan's Context section — run
   whatever tests and linters are listed there.

PHASE 3 — VERIFY AND EXIT:
8. If verification PASSES: mark the step done (\`- [ ]\` → \`- [x]\`) and stop.
9. If verification FAILS: do NOT mark the step done. Leave it as \`- [ ]\` and
   stop immediately. Do not retry or loop — ralph will start a fresh iteration
   with clean context, which often succeeds where retrying in the same context
   fails.

Rules:
- Achieve ONE outcome only, then stop.
- Do not modify other steps.
- Do not over-engineer — implement the simplest thing that satisfies the outcome.
- Do not rush to code. Understanding the codebase first leads to better solutions.
- NEVER retry in a loop. One attempt at implementation, one verification run.
  If it fails, stop. Ralph will retry with a fresh context on the next iteration.
- Only use git for reading (status, diff, log, show). Ralph handles all commits.

Tools available:
- agent-browser CLI (via Bash) for visual QA when UI changes are involved:
  \`agent-browser open <url>\`, \`agent-browser snapshot -i -c\`, \`agent-browser click @e1\`,
  \`agent-browser fill @e3 "text"\`, \`agent-browser screenshot <path>\`, \`agent-browser wait <selector|ms>\`
- Figma MCP tools for checking designs when UI work references Figma.
Use these tools when the step involves UI work. Skip them for backend-only changes.
PROMPT

    # Append project prompt if provided
    if [[ -n "$PROMPT_FILE" ]]; then
      echo ""
      echo "── Project Prompt ──────────────────────────────────────────"
      echo ""
      cat "$PROMPT_FILE"
    fi
  fi
}

PROMPT="$(build_prompt)"

# ── Dry run ───────────────────────────────────────────────────────────────────
if [[ "$DRY_RUN" = true ]]; then
  echo ""
  echo "── Dry Run ──────────────────────────────────────────────"
  echo "Plan file:      $PLAN_FILE"
  echo "Branch:         $BRANCH_NAME"
  echo "Model:          $MODEL"
  echo "Max iterations: $MAX_ITERATIONS"
  echo "Remaining:      $remaining step(s)"
  echo "Allowed tools:  $ALLOWED_TOOLS"
  echo "Prompt file:    ${PROMPT_FILE:-<none>}"
  echo "Prompt only:    $PROMPT_ONLY"
  echo ""
  echo "── Prompt ───────────────────────────────────────────────"
  echo "$PROMPT"
  echo "────────────────────────────────────────────────────────"
  exit 0
fi

# ── Create checkpoint branch ──────────────────────────────────────────────────
current_branch="$(git rev-parse --abbrev-ref HEAD)"
if [[ "$current_branch" != "$BRANCH_NAME" ]]; then
  echo "ralph: Creating branch $BRANCH_NAME from $current_branch"
  git checkout -b "$BRANCH_NAME" 2>/dev/null || git checkout "$BRANCH_NAME"
fi

# ── Main loop ─────────────────────────────────────────────────────────────────
iteration=0
steps_completed=0

trap 'echo ""; echo "ralph: Interrupted after $iteration iteration(s), $steps_completed step(s) completed on branch $BRANCH_NAME"; exit 130' INT

while [[ $iteration -lt $MAX_ITERATIONS ]]; do
  remaining=$(count_remaining)
  if [[ "$remaining" -eq 0 ]]; then
    echo "ralph: All steps complete!"
    break
  fi

  iteration=$((iteration + 1))
  echo ""
  echo "══════════════════════════════════════════════════════════"
  echo " ralph: Iteration $iteration/$MAX_ITERATIONS — $remaining step(s) remaining"
  echo "══════════════════════════════════════════════════════════"

  # Run Claude (prompt via stdin to avoid positional arg parsing issues)
  if echo "$PROMPT" | claude -p \
    --model "$MODEL" \
    --allowedTools "$ALLOWED_TOOLS"; then
    echo "ralph: Claude exited successfully"
  else
    echo "ralph: Claude exited with error (code $?) — continuing to next iteration"
  fi

  # Checkpoint: commit if there are changes
  if [[ -n "$(git status --porcelain)" ]]; then
    git add -A
    git commit -m "ralph: iteration $iteration" --no-verify
    new_remaining=$(count_remaining)
    completed_this_iter=$((remaining - new_remaining))
    if [[ $completed_this_iter -gt 0 ]]; then
      steps_completed=$((steps_completed + completed_this_iter))
      echo "ralph: Committed — $completed_this_iter step(s) done this iteration"
    else
      echo "ralph: Committed — changes made but step not yet marked complete"
    fi
  else
    echo "ralph: No changes to commit"
  fi
done

# ── Summary ───────────────────────────────────────────────────────────────────
echo ""
echo "══════════════════════════════════════════════════════════"
echo " ralph: Summary"
echo "══════════════════════════════════════════════════════════"
echo "  Iterations:      $iteration"
echo "  Steps completed: $steps_completed"
echo "  Remaining:       $(count_remaining)"
echo "  Branch:          $BRANCH_NAME"
echo ""
echo "Review with: git log --oneline $current_branch..$BRANCH_NAME"
