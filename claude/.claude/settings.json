{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "EDITOR": "nvim"
  },
  "permissions": {
    "deny": [
      "mcp__basecamp__basecamp_create_project",
      "mcp__basecamp__basecamp_update_project",
      "mcp__basecamp__basecamp_trash_project",
      "mcp__basecamp__basecamp_create_todolist",
      "mcp__basecamp__basecamp_complete_todo",
      "mcp__basecamp__basecamp_uncomplete_todo",
      "mcp__basecamp__basecamp_create_message",
      "mcp__basecamp__basecamp_update_message",
      "mcp__basecamp__basecamp_create_comment",
      "mcp__basecamp__basecamp_update_comment",
      "mcp__basecamp__basecamp_create_schedule_entry",
      "mcp__basecamp__basecamp_update_schedule_entry",
      "mcp__basecamp__basecamp_create_document",
      "mcp__basecamp__basecamp_update_document"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "/Users/lukedanielson/Workspace/crm-web",
      "/Users/lukedanielson/Workspace/partner-integration-prototype",
      "/Users/lukedanielson/Worktrees/crm-web"
    ]
  },
  "model": "sonnet[1m]",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/lukedanielson/.local/share/yax/hooks/status-reporter.sh",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/lukedanielson/.local/share/yax/hooks/status-reporter.sh",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/lukedanielson/.local/share/yax/hooks/status-reporter.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/scripts/agent-usage-logger.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/scripts/agent-usage-logger.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/lukedanielson/.local/share/yax/hooks/status-reporter.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/lukedanielson/.local/share/yax/hooks/status-reporter.sh",
            "async": true
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/lukedanielson/.local/share/yax/hooks/status-reporter.sh",
            "async": true
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/lukedanielson/.local/share/yax/hooks/status-reporter.sh",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/lukedanielson/.local/share/yax/hooks/status-reporter.sh",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/lukedanielson/.local/share/yax/hooks/status-reporter.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); current_dir=$(echo \"$input\" | jq -r '.workspace.current_dir'); model_name=$(echo \"$input\" | jq -r '.model.display_name'); printf \"➜  $(basename \"$current_dir\") \"; if git -C \"$current_dir\" rev-parse --git-dir >/dev/null 2>&1; then branch=$(git -C \"$current_dir\" branch --show-current 2>/dev/null || echo 'detached'); status=''; if ! git -C \"$current_dir\" diff-index --quiet HEAD -- 2>/dev/null; then status=' ✗'; fi; printf \"git:($branch)$status \"; fi; printf \"[$model_name]\""
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "ruby-lsp@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "wealthbox@wealthbox": true,
    "frontend-design@claude-code-plugins": true,
    "code-review@claude-code-plugins": true
  },
  "extraKnownMarketplaces": {
    "wealthbox": {
      "source": {
        "source": "git",
        "url": "git@github.com:starburstlabs/wealthbox-claude-plugin.git"
      },
      "autoUpdate": true
    },
    "claude-code-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/anthropics/claude-code.git"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "advisorModel": "opus",
  "tui": "fullscreen",
  "skipAutoPermissionPrompt": true
}
