{
  "eval_id": 1,
  "eval_name": "review-tautological-tests",
  "prompt": "Review 5 anti-pattern tests: have_many, have_db_column, respond_to, callback matcher, derived expected value. Identify issues and rewrite.",
  "assertions": [
    {
      "text": "Identifies have_many as tautological",
      "check": "grep -qi 'have_many' {file}"
    },
    {
      "text": "Identifies have_db_column as tautological",
      "check": "grep -qi 'have_db_column\\|schema\\|migration' {file}"
    },
    {
      "text": "Identifies respond_to as tautological",
      "check": "grep -qi 'respond_to' {file}"
    },
    {
      "text": "Identifies callback matcher as tautological",
      "check": "grep -qi 'callback\\|wiring\\|side.effect\\|result' {file}"
    },
    {
      "text": "Identifies derived expected value as tautological",
      "check": "grep -qiE 'expected.*formula|derived|interpolat|mirror|same.*formula|tautol' {file}"
    },
    {
      "text": "Rewritten full_name test uses literal string not interpolated attributes",
      "check": "grep -q 'eq(\"Jane Smith\")' {file} || grep -qE 'eq\\(\"[A-Z][a-z]+ [A-Z][a-z]+\"\\)' {file}"
    },
    {
      "text": "Does not reproduce the anti-pattern interpolation in the rewrite",
      "check": "! grep -qE 'contact\\.first_name.*contact\\.last_name' {file}"
    }
  ]
}
