{
  "eval_id": 2,
  "eval_name": "write-request-spec-post-contacts",
  "prompt": "Write request spec for POST /contacts: success (200 + change count), missing name (422), cross-account contact_source_id (422). Use login_with, Current.user, change matcher.",
  "assertions": [
    {
      "text": "Uses require 'spec_helper'",
      "check": "grep -q 'require.*spec_helper' {file}"
    },
    {
      "text": "Has login_with in before block",
      "check": "grep -q 'login_with' {file}"
    },
    {
      "text": "Sets Current.user in before block",
      "check": "grep -q 'Current.user' {file}"
    },
    {
      "text": "Uses change { Contact.count }.by(1) for creation assertion",
      "check": "grep -q 'change.*Contact.count.*by(1)\\|change { Contact.count }.*by(1)' {file}"
    },
    {
      "text": "Asserts HTTP status for success case (200 or :ok)",
      "check": "grep -qE 'have_http_status\\(:ok\\)|have_http_status\\(200\\)' {file}"
    },
    {
      "text": "Asserts HTTP status for validation failure (422 or :unprocessable)",
      "check": "grep -qE 'have_http_status\\(:unprocessable|have_http_status\\(422\\)' {file}"
    },
    {
      "text": "Has cross-account test case with different account or other_account",
      "check": "grep -qE 'other_account|cross.account|different.*account|another.*account' {file}"
    },
    {
      "text": "Uses response.parsed_body not JSON.parse(response.body)",
      "check": "grep -q 'parsed_body' {file} || ! grep -q 'JSON.parse' {file}"
    }
  ]
}
