theme = warp-modern

# Window chrome
macos-titlebar-style = transparent
window-padding-x = 12
window-padding-y = 8
window-padding-balance = true

# Depth effects
background-opacity = 0.98
background-blur = 20

# Subtle grain texture
background-image = ~/.config/ghostty/noise.png
background-image-opacity = 0.04
background-image-fit = none
background-image-repeat = true
