{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/scripts/agent-usage-logger.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/scripts/agent-usage-logger.sh"
          }
        ]
      }
    ]
  }
}
